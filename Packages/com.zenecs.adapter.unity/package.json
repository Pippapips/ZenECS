      "path": "Samples~/03-EntityBlueprint"
    },
    {
      "displayName": "04 - Context Binding 시스템",
      "description": "Shared Context와 Per-Entity Context 관리",
      "path": "Samples~/04-ContextBinding"
    },
    {
      "displayName": "05 - System Presets",
      "description": "ScriptableObject 기반 시스템 설정 및 관리",
      "path": "Samples~/05-SystemPresets"
    },
    {
      "displayName": "06 - View Binder 패턴",
